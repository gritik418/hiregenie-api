// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  isEmailVerified Boolean @default(false)

  emailVerificationToken String?
  emailVerificationTokenExpiry DateTime?

  resumes   Resume[]
  resumeAnalysis ResumeAnalysis[]
  resumeMatches ResumeMatchAnalysis[]
  practiceSessions PracticeSession[]
  interviewSessions InterviewSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Resume {
  id         String   @id @default(uuid())
  userId     String

  fileUrl    String
  publicId   String  

  fileName   String
  fileSize   Int?
  fileType String?

  rawText    String?
  aiSummary String?  

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysis   ResumeAnalysis[]
  resumeMatches ResumeMatchAnalysis[]
  practiceSessions PracticeSession[]
  interviewSessions InterviewSession[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ResumeAnalysis {
  id            String   @id @default(uuid())
  userId        String
  resumeId      String

  status        AnalysisStatus @default(PROCESSING)

  score         Int?  @default(0)
  breakdown Json?   
  recommendedRoles Json? 
  strengths String[]
  weaknesses      String[] 
  gaps            String[]
  suggestions   String[]      
  keywords      Json?      
  reason        String
  feedback      Json?

  user          User        @relation(fields: [userId], references: [id])
  resume        Resume      @relation(fields: [resumeId], references: [id])

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}
model ResumeMatchAnalysis {
  id String @id @default(cuid())

  status AnalysisStatus @default(PROCESSING)

  userId   String?
  resumeId String?

  targetRole String?
  jobDescription String?
  requiredExperience String?

  matchScore Int?
  fitLevel FitLevel?

  breakdown Json?

  skills Json?
  keywords Json?
  responsibilities Json?
  qualifications Json?
  certifications Json?
  experience Json?
  roleFit Json?

  strengths String[]
  gaps String[]
  suggestions String[]
  recommendedLearning String[]

  priorityActions Json?

  summary String?
  reason String?
  feedback Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume Resume? @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([resumeId])
  @@index([targetRole])
  @@index([matchScore])
  @@index([fitLevel])
}

enum FitLevel {
  VERY_LOW
  LOW
  MODERATE
  HIGH
  EXCELLENT
}

enum AnalysisStatus {
  PROCESSING
  COMPLETED
  FAILED
}

model PracticeSession {
  id          String   @id @default(cuid())

  userId      String
  resumeId    String

  status PracticeSessionStatus @default(GENERATED)

  targetRole  String

  difficulty  Difficulty

  overview Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions   PracticeQuestion[]
  result       PracticeSessionResult?

  payload Json?

  startedAt      DateTime?
  completedAt    DateTime?
  abandonedAt    DateTime?

  resume     Resume    @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([resumeId])
  @@index([status])
}


model PracticeQuestion {
  id              String   @id @default(cuid())

  sessionId       String

  category        String
  difficulty      Difficulty

  question        String

  expectedAnswer  String

  keyPoints       String[]

  hints           String[]
  evaluationCriteria String[]

  estimatedAnswerTimeSeconds Int?

  answer      String?

  status      PracticeQuestionStatus @default(PENDING)

  tags String[]

  createdAt       DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  session PracticeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionEvaluations QuestionEvaluation[]

  @@index([sessionId])
  @@index([status])
}

model PracticeSessionResult {
  id          String @id @default(cuid())

  sessionId   String @unique

  overallScore Int

  breakdown Json?

  strengths String[]
  weaknesses String[]
  suggestions String[]

  nextSteps String[]
  performanceLevel  PerformanceLevel
  hiringRecommendation HiringRecommendation

  summary String
  reason String?
  feedback Json?
  questionEvaluations QuestionEvaluation[]

  overview Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session PracticeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model QuestionEvaluation {
   id String @id @default(cuid())
   questionId String
   resultId String 
   
   score Int?
   feedback Json?
   strengths String[]
   weaknesses String[]
   suggestions String[]
   missedKeyPoints String[]
   performanceLevel  PerformanceLevel

   result   PracticeSessionResult @relation(fields: [resultId], references: [id], onDelete: Cascade)
   question PracticeQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}
               
enum HiringRecommendation {
  NOT_RECOMMENDED
  CONSIDER
  RECOMMENDED
  STRONGLY_RECOMMENDED
}

enum PerformanceLevel {
  POOR
  FAIR
  GOOD
  VERY_GOOD
  EXCELLENT
}

enum Difficulty {
  BEGINNER
  EASY
  MEDIUM
  HARD
  EXPERT
}

enum PracticeSessionStatus {
  GENERATED
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum PracticeQuestionStatus {
  PENDING
  ANSWERED
  EVALUATED
  SKIPPED
}

model InterviewSession {
  id          String   @id @default(cuid())

  userId      String
  resumeId    String

  status      InterviewStatus @default(GENERATED)

  targetRole  String
  difficulty  Difficulty
  interviewType InterviewType

  startedAt    DateTime?
  completedAt  DateTime?
  abandonedAt  DateTime?

  overview Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  report InterviewReport? 

  messages InterviewMessage[]

  @@index([userId])
  @@index([resumeId])
  @@index([status])
}

enum InterviewStatus {
  GENERATED
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum InterviewType {
  HR
  TECHNICAL
  MIXED
  MOCK
}

model InterviewMessage {
  id String @id @default(cuid())

  sessionId String

  role InterviewMessageRole

  message String

  category String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

enum InterviewMessageRole {
  SYSTEM
  ASSISTANT
  USER
}

enum InterviewReportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model InterviewReport {
  id          String                  @id @default(uuid())
  sessionId   String                  @unique

  status      InterviewReportStatus   @default(PENDING)

  overallScore Int?

  communicationScore Int?
  technicalScore     Int?
  problemSolvingScore Int?
  confidenceScore     Int?

  summary        String?
  strengths      String[]
  weaknesses     String[]
  improvements   String[]

  questionAnalysis Json?

  hiringRecommendation String?
  recommendationReason String?

  feedback Json?

  generatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}